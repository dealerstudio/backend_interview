<%= form_with model: car do |f| %>
  <% if car.errors.any? %>
    <div style="color: red; border: 1px solid red; padding: 10px; margin-bottom: 12px;">
      <strong><%= pluralize(car.errors.count, "error") %> prevented this car from being saved:</strong>
      <ul>
        <% car.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div style="margin-bottom: 10px;">
    <%= f.label :make %><br>
    <%= f.text_field :make, style: "width: 300px;" %>
  </div>

  <div style="margin-bottom: 10px;">
    <%= f.label :model %><br>
    <%= f.text_field :model, style: "width: 300px;" %>
  </div>

  <div style="margin-bottom: 10px;">
    <%= f.label :year %><br>
    <%= f.number_field :year, style: "width: 120px;" %>
  </div>

  <div style="margin-bottom: 10px;">
    <%= f.label :price %><br>
    <%= f.number_field :price, step: 0.01, style: "width: 150px;" %>
  </div>

  <div style="margin-bottom: 10px;">
    <%= f.label :vin, "VIN" %><br>
    <%= f.text_field :vin, style: "width: 300px;", maxlength: 17 %>
  </div>

  <div style="margin-bottom: 16px;">
    <%= f.submit style: "padding: 8px 20px; cursor: pointer;" %>
  </div>
<% end %>
