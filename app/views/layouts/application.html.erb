<!DOCTYPE html>
<html>
  <head>
    <title>Dealer Interview</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
  </head>
  <body>
    <nav style="padding: 10px 20px; background: #1a1a2e; color: white; display: flex; gap: 20px; align-items: center;">
      <strong>DealerApp</strong>
      <% if user_signed_in? %>
        <%= link_to "Dealerships", dealerships_path, style: "color: #adf;" %>
        <%= link_to "All Cars", cars_path, style: "color: #adf;" %>
        <span style="margin-left: auto; font-size: 0.85em;">
          <%= current_user.email %> &mdash; <%= current_user.dealership.name %>
        </span>
        <%= button_to "Sign out", destroy_user_session_path, method: :delete,
              style: "background: #c00; border: none; color: white; padding: 4px 10px; cursor: pointer;" %>
      <% end %>
    </nav>

    <main style="padding: 20px; max-width: 960px; margin: 0 auto;">
      <% if notice %>
        <p style="color: green; border: 1px solid green; padding: 8px;"><%= notice %></p>
      <% end %>
      <% if alert %>
        <p style="color: red; border: 1px solid red; padding: 8px;"><%= alert %></p>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
